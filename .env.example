# ─── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1

# ─── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_ADMIN_PASSWORD=Medion!KIS2026
OPENSEARCH_INDEX=viaticum-transcripts

# ─── Vector store: "opensearch" (prod) | "chroma" (local fallback) ────────────
VECTOR_STORE=opensearch

# ─── Speech-to-text: "stub" | "whisper" | "pioneer" ─────────────────────────
STT_PROVIDER=stub

# ─── Pioneer SLM (leave blank to use stub responses) ─────────────────────────
PIONEER_SOAP_MODEL_ID=
PIONEER_NER_MODEL_ID=
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai/v1

# ─── Parakeet STT VM (set after GCE VM is created by setup_gcp.sh) ──────────
PARAKEET_URL=http://<parakeet-internal-ip>:8001

# ─── OMI wearable (leave blank to disable) ────────────────────────────────────
OMI_API_KEY=

# ─── LLM chat (Anthropic Claude — use claude-haiku-4-5-20251001) ─────────────
ANTHROPIC_API_KEY=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=KisDb2026!
